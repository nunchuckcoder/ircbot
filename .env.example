# ═══════════════════════════════════════════════════════════════════
#  Template de configuração — copia este ficheiro para .env e preenche.
#
#      cp .env.example .env
#
#  NUNCA commites o .env real para o repositório (já está no .gitignore).
# ═══════════════════════════════════════════════════════════════════

# ──────── Ligação IRC (obrigatório) ────────
IRC_NICK=
IRC_SERVER=irc.ptnet.org
IRC_PORT=6697

# Password NickServ (OPCIONAL — deixa vazio se o servidor não usa NickServ)
IRC_PASSWORD=

# ──────── Administradores (apenas hostmasks) ────────
# Lista separada por vírgulas. Suporta wildcards * e ?.
# Para descobrir a vhost de um admin no IRC: /whois <nick>
#
# Exemplos:
#   IRC_ADMINS=NomeAdmin!*@*.vhost.com
#   IRC_ADMINS=Admin1!*@*.isp.pt,Admin2!~ident@host.exemplo.pt
#
# ⚠️ Admin-by-nick (sem '!') NÃO é aceite — o bot recusa-se a arrancar
# se detectar entradas no formato antigo. Era trivialmente contornável
# por mudança de nick.
IRC_ADMINS=

# ──────── Canais ────────
# Canais onde o bot entra ao ligar (separados por vírgulas).
CANAIS=#portugal,#informática,#cybersecurity

# Canais que geram alertas Telegram em join/part/quit. Se vazio, usa CANAIS.
CANAIS_COM_ALERTAS=

# ──────── Telegram (OPCIONAL) ────────
# TELEGRAM_BOT_TOKEN activa a integração Telegram (notificações + controlo).
# TELEGRAM_CHAT_ID é o chat principal que recebe os alertas.
# TELEGRAM_ADMIN_CHAT_IDS controla quem pode usar /status, /reconnect,
#   /restart, /quit, etc. Se vazio, usa TELEGRAM_CHAT_ID como único admin.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_IDS=

# ──────── Monitorização / Ping timeout (opcional) ────────
# Nicks de outros bots a monitorizar no IRC. Quando saem por PART, QUIT,
# KICK ou Ping timeout, é enviado um alerta Telegram.
# Se vazio, monitoriza apenas o próprio nick (IRC_NICK).
# Exemplo: IRC_MONITORED_BOTS=OutroBot,MaisUmBot
IRC_MONITORED_BOTS=

# Heartbeat activo: o bot envia PING periódico e, se não receber PONG dentro
# de IRC_PONG_TIMEOUT segundos, força reconexão e avisa no Telegram.
IRC_PING_INTERVAL=120
IRC_PONG_TIMEOUT=45

# ──────── Logging (opcional) ────────
LOG_LEVEL_FILE=INFO
LOG_LEVEL_CONSOLE=INFO
